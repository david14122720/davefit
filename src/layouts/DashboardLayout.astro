---
import BaseLayout from "./BaseLayout.astro";
import DashboardSidebar from "../components/layout/DashboardSidebar.astro";
import DashboardHeader from "../components/layout/DashboardHeader.astro";
import { getInsforgeClient } from "../lib/insforge";
import { decodeJWT } from "../lib/api-helpers";

interface Props {
    title?: string;
}

const { title = "Dashboard" } = Astro.props;
const currentPath = Astro.url.pathname;

// Identificar al usuario (Sincronización de Identidad Única)
const accessToken = Astro.cookies.get("if-access-token")?.value;
let userName = Astro.cookies.get("user_name")?.value || "Usuario";
let avatarUrl = Astro.cookies.get("user_avatar")?.value || null;
let userRol = Astro.cookies.get("user_rol")?.value || "usuario";

if (accessToken) {
    try {
        const payload = decodeJWT(accessToken);
        const userId = payload.sub || (payload as any).id;

        if (userId) {
            const insforge = getInsforgeClient(accessToken);
            const { data: dbProfile } = await insforge.database
                .from("perfiles")
                .select("nombre_completo, avatar_url, rol")
                .eq("id", userId)
                .maybeSingle();

            if (dbProfile) {
                if (dbProfile.nombre_completo) {
                    userName = dbProfile.nombre_completo.split(" ")[0];
                }
                if (dbProfile.avatar_url) avatarUrl = dbProfile.avatar_url;
                if (dbProfile.rol) userRol = dbProfile.rol;
            }
        }
    } catch (e) {
        console.error("[DashboardLayout] Error syncing identity:", e);
    }
}

const userInitial = userName.charAt(0).toUpperCase() || "U";
const isAdmin = userRol === "admin";

const today = new Date().toLocaleDateString("es-ES", {
    weekday: "long",
    year: "numeric",
    month: "long",
    day: "numeric",
});
---

<BaseLayout title={title} showNav={false}>
    <div
        class="flex min-h-screen bg-[var(--color-bg-dark)] overflow-hidden"
        transition:animate="fade"
    >
        <!-- Sidebar (Externalized) -->
        <DashboardSidebar currentPath={currentPath} transition:persist />

        <!-- Main Content Area -->
        <main
            class="flex-1 flex flex-col min-w-0 bg-[var(--color-bg-dark)] overflow-hidden"
        >
            <!-- Header (Externalized) -->
            <DashboardHeader
                title={title}
                today={today}
                userName={userName}
                userInitial={userInitial}
                avatarUrl={avatarUrl}
                isAdmin={isAdmin}
                transition:persist
            />

            <!-- Page-Specific Content with Scroll -->
            <div class="flex-1 overflow-y-auto p-4 md:p-8 custom-scrollbar">
                <slot />
            </div>
        </main>
    </div>
</BaseLayout>

<style is:global>
    /* Global scrollbar for dashboard */
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: transparent;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 10px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.1);
    }
</style>
