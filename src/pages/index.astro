  <!-- Suggestions Section -->
  <section class="py-24 bg-background-card relative overflow-hidden" id="sugerencias">
    <div
      class="absolute top-0 left-0 w-[400px] h-[400px] bg-primary/5 rounded-full blur-[150px]"
    >
