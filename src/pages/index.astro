              <div class="flex items-center gap-1" id="star-rating">
                {[1, 2, 3, 4, 5].map((star) => (
                  <button
                    type="button"
                    data-star={star}
                    class="star-btn text-2xl text-gray-500 hover:text-yellow-400 transition-colors"
                  >
                    ★
