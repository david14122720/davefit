---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { insforge } from "../lib/insforge";

// Fetch suggestions and stats
const [suggestionsResult, statsResult] = await Promise.all([
    insforge.database
        .from('suggestions')
        .select('*')
        .order('created_at', { ascending: false })
        .limit(5),
    fetch(new URL('/api/stats', Astro.url)).then(r => r.json()).catch(() => ({
        exercises: 0,
        users: 0,
        rating: 0,
        reviews: 0
    }))
]);

const suggestions = suggestionsResult.data || [];
const stats = statsResult as { exercises: number; users: number; rating: number; reviews: number };

// Format numbers
const formatNumber = (num: number): string => {
    if (num >= 1000) {
        return (num / 1000).toFixed(1).replace(/\.0$/, '') + 'k+';
    }
    return num.toString() + '+';
};
