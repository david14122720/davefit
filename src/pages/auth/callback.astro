---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Autenticando..." showNav={false}>
    <div
        class="min-h-screen flex items-center justify-center bg-[var(--color-bg-dark)]"
    >
        <div class="text-center">
            <div
                class="w-16 h-16 border-4 border-orange-500 border-t-transparent rounded-full animate-spin mx-auto mb-4"
            >
            </div>
            <h2 class="text-2xl font-bold text-white mb-2">
                Finalizando inicio de sesión
            </h2>
            <p class="text-gray-400" id="status-text">
                Sincronizando con el servidor...
            </p>
        </div>
    </div>
</BaseLayout>

<script>
    import { insforge } from "../../lib/insforge";
    import { AuthService } from "../../services/auth.service";

    async function handleCallback() {
        const statusText = document.getElementById("status-text");

        // Pequeño retardo para asegurar que el SDK procese el fragmento de la URL
        setTimeout(async () => {
            try {
                // 1. Obtener sesión del SDK (busca en fragmento/localStorage)
                const { data, error } = await insforge.auth.getCurrentSession();

                if (error) throw error;

                const session = (data as any)?.session || data;
                const token = session?.access_token || session?.accessToken;

                if (token) {
                    if (statusText)
                        statusText.textContent = "Sincronizando perfil...";

                    // 2. Sincronizar con el servidor (cookies)
                    const user = session?.user;
                    const success = await AuthService.syncSession(token, user);

                    if (!success)
                        throw new Error(
                            "Error al sincronizar sesión en servidor",
                        );

                    // 3. Éxito
                    if (statusText)
                        statusText.textContent = "¡Bienvenido! Redirigiendo...";

                    window.location.href = "/dashboard";
                } else {
                    console.warn("[Callback] No se encontró sesión en el SDK");
                    window.location.href = "/login?error=no_session";
                }
            } catch (err: any) {
                console.error("[Callback] Error:", err.message);
                if (statusText)
                    statusText.textContent = "Error: " + err.message;

                setTimeout(() => {
                    window.location.href = "/login?error=callback_failed";
                }, 1500);
            }
        }, 500);
    }

    // Ejecutar inmediatamente
    handleCallback();
</script>
