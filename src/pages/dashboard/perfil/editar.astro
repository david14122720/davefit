---
import DashboardLayout from "../../../layouts/DashboardLayout.astro";
import ProfileAvatarUpload from "../../../components/profile/ProfileAvatarUpload.astro";
import { getInsforgeClient } from "../../../lib/insforge";
import { decodeJWT } from "../../../lib/api-helpers";

// Auth and Data fetching
const accessToken = Astro.cookies.get("if-access-token")?.value;
if (!accessToken) return Astro.redirect("/login");

const payload = decodeJWT(accessToken);
const userId = payload.sub || (payload as any).id;

const insforge = getInsforgeClient(accessToken);
const { data: perfil } = await insforge.database
    .from("perfiles")
    .select("*")
    .eq("id", userId)
    .single();

if (!perfil) return Astro.redirect("/dashboard/perfil");
---

<DashboardLayout title="Editar Perfil">
    <div class="max-w-4xl mx-auto py-8 px-4">
        <!-- Header Section -->
        <div class="flex items-center gap-4 mb-8">
            <a
                href="/dashboard/perfil"
                class="p-2 bg-white/5 hover:bg-white/10 rounded-xl transition-all group"
            >
                <svg
                    class="w-6 h-6 text-gray-400 group-hover:text-orange-500"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
                </svg>
            </a>
            <h2 class="text-3xl font-extrabold text-white tracking-tight">
                Datos <span class="text-orange-500">Personales</span>
            </h2>
        </div>

        <form
            id="edit-profile-form"
            class="space-y-8"
            enctype="multipart/form-data"
        >
            <!-- Profile Info Card -->
            <div
                class="glass-panel p-8 rounded-3xl border border-white/5 shadow-2xl relative overflow-hidden group"
            >
                <div
                    class="absolute -top-24 -right-24 w-64 h-64 bg-orange-500/5 rounded-full blur-3xl group-hover:bg-orange-500/10 transition-colors duration-700"
                >
                </div>

                <!-- Extracted Component -->
                <ProfileAvatarUpload
                    currentAvatar={perfil.avatar_url}
                    userName={perfil.nombre_completo || "Usuario"}
                />

                <!-- Form Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-6">
                    <div class="space-y-2">
                        <label
                            class="text-xs font-bold text-gray-500 uppercase tracking-widest ml-1"
                            >Nombre Completo</label
                        >
                        <input
                            type="text"
                            name="nombre_completo"
                            value={perfil.nombre_completo}
                            class="w-full bg-white/5 border border-white/10 text-white rounded-2xl px-5 py-3.5 focus:outline-none focus:ring-2 focus:ring-orange-500/50 focus:border-orange-500/50 transition-all placeholder-gray-600"
                            placeholder="Ej: Daniel Alejandro"
                            required
                        />
                    </div>

                    <div class="space-y-2">
                        <label
                            class="text-xs font-bold text-gray-500 uppercase tracking-widest ml-1"
                            >Género</label
                        >
                        <select
                            name="genero"
                            class="w-full bg-white/5 border border-white/10 text-white rounded-2xl px-5 py-3.5 focus:outline-none focus:ring-2 focus:ring-orange-500/50 transition-all appearance-none cursor-pointer"
                        >
                            <option
                                value="masculino"
                                selected={perfil.genero === "masculino"}
                                >Masculino</option
                            >
                            <option
                                value="femenino"
                                selected={perfil.genero === "femenino"}
                                >Femenino</option
                            >
                            <option
                                value="otro"
                                selected={perfil.genero === "otro"}>Otro</option
                            >
                        </select>
                    </div>

                    <div class="space-y-2">
                        <label
                            class="text-xs font-bold text-gray-500 uppercase tracking-widest ml-1"
                            >Fecha de Nacimiento</label
                        >
                        <input
                            type="date"
                            name="fecha_nacimiento"
                            value={perfil.fecha_nacimiento}
                            class="w-full bg-white/5 border border-white/10 text-white rounded-2xl px-5 py-3.5 focus:outline-none focus:ring-2 focus:ring-orange-500/50 transition-all [color-scheme:dark]"
                        />
                    </div>

                    <div class="space-y-2">
                        <label
                            class="text-xs font-bold text-gray-500 uppercase tracking-widest ml-1"
                            >Objetivo Fitness</label
                        >
                        <select
                            name="objetivo"
                            class="w-full bg-white/5 border border-white/10 text-white rounded-2xl px-5 py-3.5 focus:outline-none focus:ring-2 focus:ring-orange-500/50 transition-all appearance-none cursor-pointer"
                        >
                            <option
                                value="tonificar"
                                selected={perfil.objetivo === "tonificar"}
                                >Perder Peso</option
                            >
                            <option
                                value="ganar_fuerza"
                                selected={perfil.objetivo === "ganar_fuerza"}
                                >Ganar Músculo</option
                            >
                            <option
                                value="mantener_forma"
                                selected={perfil.objetivo === "mantener_forma"}
                                >Mantenerse</option
                            >
                        </select>
                    </div>

                    <div class="space-y-2">
                        <label
                            class="text-xs font-bold text-gray-500 uppercase tracking-widest ml-1"
                            >Peso Actual (kg)</label
                        >
                        <input
                            type="number"
                            step="0.1"
                            name="peso_actual"
                            value={perfil.peso_actual}
                            class="w-full bg-white/5 border border-white/10 text-white rounded-2xl px-5 py-3.5 focus:outline-none focus:ring-2 focus:ring-orange-500/50 transition-all"
                        />
                    </div>

                    <div class="space-y-2">
                        <label
                            class="text-xs font-bold text-gray-500 uppercase tracking-widest ml-1"
                            >Altura (cm)</label
                        >
                        <input
                            type="number"
                            name="altura"
                            value={perfil.altura}
                            class="w-full bg-white/5 border border-white/10 text-white rounded-2xl px-5 py-3.5 focus:outline-none focus:ring-2 focus:ring-orange-500/50 transition-all"
                        />
                    </div>
                </div>

                <div
                    class="mt-10 pt-8 border-t border-white/5 flex flex-col md:flex-row gap-4 items-center justify-between"
                >
                    <p class="text-gray-500 text-sm italic">
                        Tus datos están protegidos y solo se usan para
                        personalizar tu experiencia.
                    </p>
                    <button
                        type="submit"
                        id="save-btn"
                        class="w-full md:w-auto px-10 py-4 bg-orange-500 hover:bg-orange-400 text-black font-extrabold rounded-2xl shadow-xl shadow-orange-500/20 hover:shadow-orange-500/30 transition-all duration-300 transform active:scale-95 flex items-center justify-center gap-2 group"
                    >
                        <span id="save-text">Guardar cambios</span>
                        <svg
                            id="save-icon"
                            class="w-5 h-5 transition-transform group-hover:translate-x-1"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                        </svg>
                        <svg
                            id="loading-icon"
                            class="w-5 h-5 animate-spin hidden"
                            viewBox="0 0 24 24"
                            ><circle
                                class="opacity-25"
                                cx="12"
                                cy="12"
                                r="10"
                                stroke="currentColor"
                                stroke-width="4"></circle><path
                                class="opacity-75"
                                fill="currentColor"
                                d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"
                            ></path></svg
                        >
                    </button>
                </div>
            </div>
        </form>
    </div>

    <!-- Success Modal -->
    <div
        id="success-modal"
        class="fixed inset-0 z-50 hidden bg-[var(--color-bg-dark)]/80 backdrop-blur-sm items-center justify-center p-4"
    >
        <div
            class="bg-neutral-900 border border-white/10 rounded-3xl p-8 max-w-sm w-full text-center shadow-2xl transform transition-all scale-95 opacity-0 duration-300"
        >
            <div
                class="w-20 h-20 bg-orange-500/20 text-orange-500 rounded-full flex items-center justify-center mx-auto mb-6 scale-110 shadow-lg shadow-orange-500/10"
            >
                <svg
                    class="w-10 h-10"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="3"
                        d="M5 13l4 4L19 7"></path>
                </svg>
            </div>
            <h3 class="text-2xl font-bold text-white mb-2">
                ¡Perfil Actualizado!
            </h3>
            <p class="text-gray-400 mb-8">
                Todos los cambios se han guardado correctamente en la base de
                datos.
            </p>
            <button
                id="close-modal"
                class="w-full py-4 bg-orange-500 hover:bg-orange-400 text-black font-extrabold rounded-2xl transition-all shadow-lg active:scale-95"
            >
                Entendido
            </button>
        </div>
    </div>
</DashboardLayout>

<script>
    const form = document.querySelector(
        "#edit-profile-form",
    ) as HTMLFormElement;
    const saveBtn = document.getElementById("save-btn") as HTMLButtonElement;
    const saveIcon = document.getElementById("save-icon") as HTMLElement;
    const loadingIcon = document.getElementById("loading-icon") as HTMLElement;
    const saveText = document.getElementById("save-text") as HTMLElement;
    const avatarInput = document.getElementById("avatar") as HTMLInputElement;
    const avatarPreview = document.getElementById(
        "avatar-preview",
    ) as HTMLDivElement;
    const successModal = document.getElementById(
        "success-modal",
    ) as HTMLDivElement;
    const closeModal = document.getElementById(
        "close-modal",
    ) as HTMLButtonElement;
    const fileNameDisplay = document.getElementById(
        "file-name",
    ) as HTMLParagraphElement;
    const uploadStatus = document.getElementById(
        "upload-status",
    ) as HTMLParagraphElement;

    let selectedAvatar: File | null = null;

    avatarInput?.addEventListener("change", (e) => {
        const file = (e.target as HTMLInputElement).files?.[0];
        if (file) {
            selectedAvatar = file;
            const reader = new FileReader();
            reader.onload = (e) => {
                avatarPreview.innerHTML = `<img src="${e.target?.result}" alt="Preview" class="w-full h-full object-cover" />`;
            };
            reader.readAsDataURL(file);
            fileNameDisplay.textContent = `📄 ${file.name}`;
            fileNameDisplay.classList.remove("hidden");
            uploadStatus.textContent = "Listo para subir";
            uploadStatus.classList.remove("hidden");
        }
    });

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        saveBtn.disabled = true;
        saveText.textContent = "Guardando...";
        saveIcon.classList.add("hidden");
        loadingIcon.classList.remove("hidden");

        const formData = new FormData(form);
        if (selectedAvatar) formData.append("avatar", selectedAvatar);

        try {
            const response = await fetch("/api/update-profile", {
                method: "POST",
                body: formData,
            });
            const result = await response.json();

            if (result.success) {
                successModal.classList.remove("hidden");
                successModal.classList.add("flex");
                setTimeout(() => {
                    successModal
                        .querySelector("div")
                        ?.classList.remove("opacity-0", "scale-95");
                }, 10);
            } else {
                throw new Error(result.error || "Error al actualizar");
            }
        } catch (err: any) {
            console.error(err);
            alert("Error: " + (err.message || "No se pudo guardar"));
        } finally {
            saveBtn.disabled = false;
            saveText.textContent = "Guardar cambios";
            saveIcon.classList.remove("hidden");
            loadingIcon.classList.add("hidden");
        }
    });

    closeModal?.addEventListener(
        "click",
        () => (window.location.href = "/dashboard/perfil"),
    );
</script>

<style>
    .glass-panel {
        background: rgba(20, 20, 20, 0.6);
        backdrop-filter: blur(12px);
    }
</style>
