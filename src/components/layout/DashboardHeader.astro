---
import { Image } from "astro:assets";

interface Props {
    title: string;
    today: string;
    userName: string;
    userInitial: string;
    avatarUrl?: string | null;
    isAdmin: boolean;
}

const { title, today, userName, userInitial, avatarUrl, isAdmin } = Astro.props;
---

<header
    class="h-16 md:h-20 flex items-center justify-between px-4 md:px-8 border-b border-white/5 relative z-20 bg-[var(--color-bg-dark)]/80 backdrop-blur-md"
>
    <div>
        <h1 class="text-xl md:text-2xl font-bold text-white">
            {title}
        </h1>
        <p class="hidden md:block text-sm text-gray-500">
            {today}
        </p>
    </div>

    <!-- User Menu -->
    <div class="flex items-center gap-4">
        <!-- Notifications (Static for now) -->
        <button
            class="relative p-2 text-gray-400 hover:text-white transition-colors rounded-lg hover:bg-white/5"
            aria-label="Notificaciones"
        >
            <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"
                ></path>
            </svg>
            <span
                class="absolute top-1.5 right-1.5 w-2 h-2 bg-orange-500 rounded-full"
            ></span>
        </button>

        <!-- User Profile Link -->
        <a
            href="/dashboard/perfil"
            class="flex items-center gap-3 group focus:outline-none focus:ring-2 focus:ring-orange-500/50 rounded-full pr-2"
        >
            <div class="text-right hidden md:block">
                <p
                    class="text-sm font-medium text-white line-clamp-1 max-w-[150px]"
                >
                    {userName}
                </p>
                <p class="text-xs text-gray-500">
                    {isAdmin ? "Admin" : "Miembro"}
                </p>
            </div>
            <div
                class={`w-10 h-10 md:w-12 md:h-12 rounded-full flex items-center justify-center font-bold text-white text-lg overflow-hidden ring-2 ring-white/10 group-hover:ring-orange-400 transition-all ${
                    avatarUrl
                        ? ""
                        : "bg-gradient-to-br from-orange-500 to-orange-600 shadow-lg shadow-orange-500/10"
                }`}
            >
                {
                    avatarUrl ? (
                        <img
                            src={avatarUrl}
                            alt={userName}
                            class="w-full h-full object-cover"
                            loading="eager"
                        />
                    ) : (
                        <span class="text-base">{userInitial}</span>
                    )
                }
            </div>
        </a>
    </div>
</header>
