---
import { getInsforgeClient } from "../../lib/insforge";

interface Props {
    currentPath: string;
}

const { currentPath } = Astro.props;

const menuItems = [
    {
        name: "Dashboard",
        path: "/dashboard",
        icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6",
    },
    {
        name: "Rutinas",
        path: "/dashboard/rutinas",
        icon: "M13 10V3L4 14h7v7l9-11h-7z",
    },
    {
        name: "Dieta",
        path: "/dashboard/dieta",
        icon: "M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3",
    },
    {
        name: "Historial",
        path: "/dashboard/historial",
        icon: "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z",
    },
];
---

<aside
    class="fixed inset-y-0 left-0 z-40 w-64 md:relative md:flex flex-col bg-[var(--color-bg-dark)]/95 border-r border-white/5 transition-all duration-300 hidden"
>
    <!-- Logo -->
    <div class="h-20 flex items-center px-8">
        <a
            href="/dashboard"
            class="text-2xl font-bold tracking-tighter text-white"
        >
            Dave<span class="text-orange-500">Fit</span>
        </a>
    </div>

    <!-- Navigation -->
    <nav class="flex-1 px-4 py-6 space-y-1">
        {
            menuItems.map((item) => {
                const isActive = currentPath === item.path;
                return (
                    <a
                        href={item.path}
                        class={`flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 group ${
                            isActive
                                ? "bg-orange-500 text-black font-bold shadow-lg shadow-orange-500/20"
                                : "text-gray-400 hover:text-white hover:bg-white/5"
                        }`}
                    >
                        <svg
                            class={`w-5 h-5 ${
                                isActive
                                    ? "text-black"
                                    : "text-gray-500 group-hover:text-orange-500"
                            }`}
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d={item.icon}
                            />
                        </svg>
                        <span>{item.name}</span>
                    </a>
                );
            })
        }
    </nav>

    <!-- Bottom Actions -->
    <div class="p-4 mt-auto">
        <div
            class="p-4 rounded-2xl bg-gradient-to-br from-orange-500/10 to-orange-600/5 border border-orange-500/10"
        >
            <p
                class="text-xs text-orange-400 font-bold mb-1 uppercase tracking-wider text-center"
            >
                Plan Premium
            </p>
            <p class="text-[10px] text-gray-500 text-center mb-3">
                Acceso a todas las funciones
            </p>
            <button
                class="w-full py-2 bg-orange-500 hover:bg-orange-400 text-black text-xs font-bold rounded-lg transition-colors"
            >
                Mejorar Plan
            </button>
        </div>

        <button
            id="logout-btn"
            class="w-full mt-4 flex items-center gap-3 px-4 py-3 text-gray-400 hover:text-red-400 hover:bg-red-500/10 rounded-xl transition-all"
        >
            <svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"
                ></path>
            </svg>
            <span>Cerrar Sesión</span>
        </button>
    </div>
</aside>

<script>
    import { insforge } from "../../lib/insforge";

    function setupLogout() {
        const btn = document.getElementById("logout-btn");
        if (!btn) return;
        
        btn.addEventListener("click", async (e) => {
            e.preventDefault();
            try {
                await insforge.auth.signOut();
                await fetch("/api/auth/logout", { method: "POST", credentials: "include" });
                window.location.href = "/login";
            } catch (err) {
                console.error("Error signing out:", err);
                window.location.href = "/login";
            }
        });
    }

    setupLogout();
    document.addEventListener("astro:page-load", setupLogout);
</script>
